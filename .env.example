# =============================================================
#  Pulso — Plataforma de salud digital argentina
#  Nativos Consultora Digital
# =============================================================
#  Copiar a `.env` en raíz para variables compartidas.
#  Cada app tiene su propio `.env` (ver apps/*/.env.example).
#  NUNCA commitear `.env` reales — solo `.env.example`.
# =============================================================

NODE_ENV=development
LOG_LEVEL=debug

# --- Base de datos PostgreSQL --------------------------------
DATABASE_URL=postgresql://pulso:pulso@localhost:5432/pulso?schema=public
DIRECT_URL=postgresql://pulso:pulso@localhost:5432/pulso?schema=public

# --- Auth -----------------------------------------------------
JWT_SECRET=cambiar-en-produccion-usar-cadena-aleatoria-larga-min-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d

# --- IA (Pulso Mica) — opcional, si no hay key Mica usa mock --
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- URLs -----------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# --- Audit / Hash chain ---------------------------------------
AUDIT_HASH_SALT=cambiar-en-produccion-cadena-aleatoria

# --- SMTP (notificaciones email; Mailhog en dev) -------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Pulso <no-reply@pulso.local>

# --- Storage S3-compatible (MinIO en dev) --------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pulso-clinical
S3_ACCESS_KEY=pulso
S3_SECRET_KEY=pulso-minio-dev
