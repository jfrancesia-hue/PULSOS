{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "./dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "incremental": true,
    "declaration": false,
    "noEmit": false,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "paths": {
      "@pulso/types": ["../../packages/types/src/index.ts"],
      "@pulso/types/*": ["../../packages/types/src/*"],
      "@pulso/db": ["../../packages/db/src/index.ts"],
      "@pulso/auth": ["../../packages/auth/src/index.ts"],
      "@pulso/audit": ["../../packages/audit/src/index.ts"],
      "@pulso/ai": ["../../packages/ai/src/index.ts"],
      "@pulso/notifications": ["../../packages/notifications/src/index.ts"],
      "@pulso/integrations": ["../../packages/integrations/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/types/src/**/*",
    "../../packages/db/src/**/*",
    "../../packages/auth/src/**/*",
    "../../packages/audit/src/**/*",
    "../../packages/ai/src/**/*",
    "../../packages/notifications/src/**/*",
    "../../packages/integrations/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "test"]
}
